@{
    ViewData["Title"] = "Rescued Foxes";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold">Rescued Foxes 🦊</h1>
        <p class="lead">
            See rescued foxes that are registered in the Fox Shelter system.
        </p>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="bg-white rounded shadow-sm p-4 h-100 text-center">
                <img src="https://placehold.co/300x200?text=Fox" class="img-fluid rounded mb-3" alt="Fox image" />

                <h4>Foxy</h4>
                <p class="text-muted">Found near Făget Forest</p>

                <p>
                    A young fox rescued from a peri-urban area. Currently stable and under observation.
                </p>

                <span class="badge bg-success mb-3">Available for adoption</span>

                <div>
                    <a href="#" class="btn btn-outline-dark btn-sm">View details</a>
                    <a href="#" class="btn btn-outline-success btn-sm">See on map</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="bg-white rounded shadow-sm p-4 h-100 text-center">
                <img src="https://placehold.co/300x200?text=Fox" class="img-fluid rounded mb-3" alt="Fox image" />

                <h4>Rusty</h4>
                <p class="text-muted">Found near Hoia Forest</p>

                <p>
                    Adult fox found close to a road. It needs more monitoring before adoption.
                </p>

                <span class="badge bg-warning text-dark mb-3">Under observation</span>

                <div>
                    <a href="#" class="btn btn-outline-dark btn-sm">View details</a>
                    <a href="#" class="btn btn-outline-success btn-sm">See on map</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="bg-white rounded shadow-sm p-4 h-100 text-center">
                <img src="https://placehold.co/300x200?text=Fox" class="img-fluid rounded mb-3" alt="Fox image" />

                <h4>Amber</h4>
                <p class="text-muted">Found near forest edge</p>

                <p>
                    Recently reported fox. The rescue team is still checking its condition and location.
                </p>

                <span class="badge bg-secondary mb-3">Not available yet</span>

                <div>
                    <a href="#" class="btn btn-outline-dark btn-sm">View details</a>
                    <a href="#" class="btn btn-outline-success btn-sm">See on map</a>
                </div>
            </div>
        </div>

    </div>
</div>