@model ProiectII.DTO.AuthAccount.LoginDto
@{
    ViewData["Title"] = "Login";
}

<div class="form-container" style="max-width: 450px;">
    <h2 class="form-title text-center">Login</h2>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-4">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control" placeholder="Enter email" required />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" required />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-custom w-100">Login</button>
        </div>
    </form>

    <div class="mt-4 text-center">
        Don't have an account? <a asp-controller="Account" asp-action="Register" style="color: var(--secondary-color); font-weight: bold;">Register here</a>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
