@{
    ViewData["Title"] = "All Reports";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold">All Reports</h1>
        <p class="lead">
            View user reports related to fox sightings and possible habitat risks.
        </p>
    </div>

    <div id="loadingMessage" class="alert alert-info text-center">
        Loading reports...
    </div>

    <div id="errorMessage" class="alert alert-danger text-center d-none">
        Could not load reports.
    </div>

    <div id="noReportsMessage" class="alert alert-warning text-center d-none">
        No reports available.
    </div>

    <div id="reportsContainer" class="row g-4">
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            loadReports();
        });

        async function loadReports() {
            const reportsContainer = document.getElementById("reportsContainer");
            const loadingMessage = document.getElementById("loadingMessage");
            const errorMessage = document.getElementById("errorMessage");
            const noReportsMessage = document.getElementById("noReportsMessage");

            try {
                const response = await fetch("/Reports/GetAll");

                if (!response.ok) {
                    throw new Error("Request failed");
                }

                const reports = await response.json();

                loadingMessage.classList.add("d-none");

                if (!reports || reports.length === 0) {
                    noReportsMessage.classList.remove("d-none");
                    return;
                }

                reportsContainer.innerHTML = "";

                reports.forEach(report => {
                    const description = report.description || report.Description || "No description available";
                    const reporterName = report.reporterName || report.ReporterName || "Unknown reporter";
                    const status = report.status || report.Status || "Pending";
                    const imageUrl = report.imageUrl || report.ImageUrl || "";
                    const createdAt = report.createdAt || report.CreatedAt || report.reportDate || report.ReportDate || "";
                    const location = report.location || report.Location || null;

                    let locationText = "Location not available";

                    if (location) {
                        const locationName = location.name || location.Name || "";
                        const coordinate = location.coordinate || location.Coordinate || null;

                        if (coordinate) {
                            const lat = coordinate.latitude || coordinate.Latitude;
                            const lng = coordinate.longitude || coordinate.Longitude;

                            locationText = `${locationName} (${lat}, ${lng})`;
                        } else if (locationName) {
                            locationText = locationName;
                        }
                    } else {
                        const latitude = report.latitude || report.Latitude;
                        const longitude = report.longitude || report.Longitude;

                        if (latitude && longitude) {
                            locationText = `${latitude}, ${longitude}`;
                        }
                    }

                    const dateText = createdAt ? new Date(createdAt).toLocaleString() : "Date not available";

                    const imageSection = imageUrl
                        ? `<img src="${imageUrl}" class="img-fluid rounded mb-3 report-image" alt="Report image">`
                        : `<div class="report-placeholder mb-3">No image</div>`;

                    const card = `
                        <div class="col-md-4">
                            <div class="bg-white rounded shadow-sm p-4 h-100">
                                ${imageSection}

                                <h4 class="mb-3">Report</h4>

                                <p class="text-muted mb-2">
                                    <strong>Reporter:</strong> ${reporterName}
                                </p>

                                <p class="mb-2">
                                    <strong>Description:</strong><br>
                                    ${description}
                                </p>

                                <p class="mb-2">
                                    <strong>Location:</strong><br>
                                    ${locationText}
                                </p>

                                <p class="mb-2">
                                    <strong>Date:</strong><br>
                                    ${dateText}
                                </p>

                                <span class="badge bg-warning text-dark">${status}</span>
                            </div>
                        </div>
                    `;

                    reportsContainer.innerHTML += card;
                });
            } catch (error) {
                loadingMessage.classList.add("d-none");
                errorMessage.classList.remove("d-none");
                console.error(error);
            }
        }
    </script>
}