@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Fox Shelter 🦊</h1>
        <p class="text-muted fs-5 mb-2">“NO CONCRETE SLOP IN THIS DEN”</p>
        <p class="lead">
            Protecting foxes affected by urban expansion and habitat destruction.
        </p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
            <div class="bg-white rounded shadow-sm p-4 h-100 text-center">
                <h4>About</h4>
                <p class="text-muted">Learn more about the purpose of the project.</p>
                <a class="btn btn-primary" asp-controller="Home" asp-action="About">Open</a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="bg-white rounded shadow-sm p-4 h-100 text-center">
                <h4>Map</h4>
                <p class="text-muted">View important fox locations on the map.</p>
                <a class="btn btn-success" asp-controller="Home" asp-action="Map">Open</a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="bg-white rounded shadow-sm p-4 h-100 text-center">
                <h4>Rescued Foxes</h4>
                <p class="text-muted">See rescued foxes available in the system.</p>
                <a class="btn btn-dark" href="#">Open</a>
            </div>
        </div>
    </div>
</div>