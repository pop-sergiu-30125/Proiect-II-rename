<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProiectII</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProiectII.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div style="background-color: #add8e6; height: 60px; width: 100%; display: flex; align-items: center; padding-left: 20px; color: #333; font-size: 24px; font-weight: bold; margin-bottom: 5px;">
            Fox Shelter Application
        </div>

        <div style="background-color: #add8e6; height: 40px; width: 100%; display: flex; align-items: center; gap: 20px; padding-left: 20px;">
            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index" style="font-weight: 500;">Home</a>
            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Map" style="font-weight: 500;">Map</a>
            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="About" style="font-weight: 500;">About</a>
            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Login" style="font-weight: 500;">Login</a>
        </div>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Fox Shelter Application
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>